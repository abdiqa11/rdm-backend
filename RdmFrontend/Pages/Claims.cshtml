@page
@model RdmFrontend.Pages.ClaimsModel

<h1>User Claims</h1>

@if (!Model.UserClaims.Any())
{
    <p>No claims found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Type</th>
                <th>Value</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var claim in Model.UserClaims)
        {
            <tr>
                <td>@claim.Type</td>
                <td>@claim.Value</td>
            </tr>
        }
        </tbody>
    </table>
}
